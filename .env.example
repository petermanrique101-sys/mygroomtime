DATABASE_URL=postgresql://mygroomtime:mygroomtime@localhost:5433/mygroomtime
# Sessions (chunk 3) + BullMQ scheduled SMS reminders (chunk 15) both live in this Redis.
# BullMQ requires the same URL to be reachable for the worker process; in production this
# would be Upstash, in dev it's the docker-compose container on 6379.
REDIS_URL=redis://localhost:6379
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
WEB_ORIGIN=http://localhost:5173
COOKIE_SECRET=replace-me-in-prod-with-at-least-32-bytes
MAGIC_LINK_SECRET=replace-me-in-prod-with-at-least-32-bytes
# Signs the chunk-17 customer reschedule link JWT. Treat like MAGIC_LINK_SECRET — 32+ bytes
# in prod. Reused across reschedule-link issue + verify; rotating invalidates outstanding
# links (acceptable for v1; chunk 22 may add per-tenant keys).
RESCHEDULE_TOKEN_SECRET=replace-me-in-prod-with-at-least-32-bytes

# Stripe
STRIPE_MODE=twin
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_twin_default
STRIPE_TWIN_URL=http://localhost:4242
STRIPE_TWIN_PORT=4242
STRIPE_TWIN_PUBLIC_ORIGIN=http://localhost:4242
STRIPE_TWIN_WEBHOOK_URL=http://localhost:3000/webhooks/stripe
STRIPE_PRICE_ID_STARTER=price_starter_twin
STRIPE_PRICE_ID_PRO=price_pro_twin
STRIPE_PRICE_ID_BUSINESS=price_business_twin
# Publishable key for the customer browser. Twin: any pk_twin_ string (the web detects
# this prefix and uses a stub Pay button). Live: a real Stripe key (pk_test_ / pk_live_).
STRIPE_PUBLISHABLE_KEY=pk_twin_anything
VITE_STRIPE_PUBLISHABLE_KEY=pk_twin_anything

# Twilio
TWILIO_MODE=twin
TWILIO_ACCOUNT_SID=AC_test_replaceme
TWILIO_AUTH_TOKEN=test_replaceme
TWILIO_FROM_NUMBER=+15555550100
TWILIO_TWIN_URL=http://localhost:4243
TWILIO_TWIN_PORT=4243
# Where the twin will POST inbound webhooks (the api's twilio webhook). Used in dev so
# the twin's /__twin_inbound test helper can fire signed inbound POSTs without the
# integrator having to know the API origin.
TWILIO_TWIN_INBOUND_WEBHOOK_URL=http://localhost:3000/webhooks/twilio

# Google Calendar
GCAL_MODE=twin
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GCAL_TWIN_URL=http://localhost:4244

# Google Maps
GMAPS_MODE=twin
GOOGLE_MAPS_API_KEY=
GMAPS_TWIN_URL=http://localhost:4245
GMAPS_TWIN_PORT=4245

# Geocoding (shares GOOGLE_MAPS_API_KEY in live mode)
GEOCODE_MODE=twin
GEOCODE_TWIN_URL=http://localhost:4246
GEOCODE_TWIN_PORT=4246
