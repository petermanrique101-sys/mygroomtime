{
  "name": "mygroomtime",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "preflight": "node scripts/preflight.mjs",
    "dev": "pnpm preflight && docker compose up -d && turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @mygroomtime/db db:generate",
    "db:migrate": "pnpm --filter @mygroomtime/db db:migrate",
    "db:migrate:dev": "pnpm --filter @mygroomtime/db db:migrate:dev",
    "db:reset": "pnpm --filter @mygroomtime/db db:reset",
    "db:seed": "pnpm --filter @mygroomtime/db db:seed",
    "db:studio": "pnpm --filter @mygroomtime/db db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "twin:gmaps": "pnpm --filter @mygroomtime/twin-google-maps dev",
    "twin:geocode": "pnpm --filter @mygroomtime/twin-geocode dev",
    "twin:stripe": "pnpm --filter @mygroomtime/twin-stripe dev",
    "twin:twilio": "pnpm --filter @mygroomtime/twin-twilio dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  }
}
