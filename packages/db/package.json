{
  "name": "@mygroomtime/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force --skip-seed",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
