generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  unpaid
  starter
  pro
  business
  past_due
  canceled
}

enum UserRole {
  owner
  groomer
  dispatcher
}

enum CoatType {
  short
  medium
  long
  curly
  double
  wire
}

enum AppointmentStatus {
  scheduled
  on_the_way
  started
  completed
  canceled
  no_show
}

enum SmsDirection {
  out
  in
}

enum SmsStatus {
  pending
  sent
  error
  skipped_tier
  skipped_opt_out
}

enum WebhookSource {
  stripe
  twilio
}

enum WebhookProcessingStatus {
  received
  processed
  failed
}

enum BookingRequestStatus {
  pending_payment
  succeeded
  failed
  expired
  promoted
}

model Tenant {
  id                       String    @id @default(cuid())
  slug                     String    @unique
  businessName             String
  phone                    String?
  plan                     PlanTier  @default(unpaid)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripeSubscriptionItemId String?
  stripeSubscriptionStatus String?
  currentPeriodEnd         DateTime?
  pastDueAt                DateTime?
  lastPlanChangeAt         DateTime?
  stripeConnectAccountId        String?   @unique
  stripeConnectChargesEnabled   Boolean   @default(false)
  stripeConnectPayoutsEnabled   Boolean   @default(false)
  stripeConnectStatusUpdatedAt  DateTime?
  defaultServiceAreaZips   String[]  @default([])
  defaultBufferMinutes     Int       @default(15)
  smsRemindersEnabled      Boolean   @default(false)
  depotAddressStreet       String?
  depotAddressCity         String?
  depotAddressZip          String?
  depotLat                 Float?
  depotLng                 Float?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  users               User[]
  vehicles            Vehicle[]
  services            Service[]
  clients             Client[]
  pets                Pet[]
  appointments        Appointment[]
  recurringSeries     RecurringSeries[]
  bookingPageRequests BookingPageRequest[]
  smsMessages         SmsMessage[]
  planChanges         TenantPlanChange[]
}

model TenantPlanChange {
  id                   String   @id @default(cuid())
  tenantId             String
  fromPlan             PlanTier
  toPlan               PlanTier
  prorationAmountCents Int      @default(0)
  stripeEventId        String?  @unique
  createdAt            DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model User {
  id             String    @id @default(cuid())
  tenantId       String
  email          String
  hashedPassword String?
  role           UserRole  @default(owner)
  name           String
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehiclesAssigned  Vehicle[]     @relation("VehicleAssignedGroomer")
  appointments      Appointment[] @relation("AppointmentGroomer")
  preferredByClients Client[]     @relation("ClientPreferredGroomer")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Vehicle {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  assignedGroomerId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedGroomer User?         @relation("VehicleAssignedGroomer", fields: [assignedGroomerId], references: [id], onDelete: SetNull)
  appointments    Appointment[]

  @@index([tenantId])
}

model Service {
  id             String    @id @default(cuid())
  tenantId       String
  name           String
  durationMin    Int
  basePriceCents Int
  depositCents   Int       @default(0)
  color          String    @default("#6b7280")
  active         Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  recurringSeries RecurringSeries[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model Client {
  id                 String    @id @default(cuid())
  tenantId           String
  name               String
  phone              String
  email              String?
  addressStreet      String
  addressCity        String
  addressState       String    @default("TX")
  addressZip         String
  addressLat         Float?
  addressLng         Float?
  addressVerified    Boolean   @default(false)
  preferredGroomerId String?
  notes              String    @default("")
  smsOptOut          Boolean   @default(false)
  smsOptOutAt        DateTime?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  preferredGroomer    User?                @relation("ClientPreferredGroomer", fields: [preferredGroomerId], references: [id], onDelete: SetNull)
  pets                Pet[]
  appointments        Appointment[]
  recurringSeries     RecurringSeries[]
  smsMessages         SmsMessage[]
  bookingPageRequests BookingPageRequest[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, deletedAt])
}

model Pet {
  id                String    @id @default(cuid())
  tenantId          String
  clientId          String
  name              String
  breed             String
  weightLb          Float?
  coatType          CoatType
  temperamentNotes  String    @default("")
  preferredCutStyle String    @default("")
  vaccinationExpiry DateTime?
  photoUrl          String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  recurringSeries RecurringSeries[]

  @@index([tenantId])
  @@index([clientId])
  @@index([tenantId, deletedAt])
}

model Appointment {
  id                String            @id @default(cuid())
  tenantId          String
  clientId          String
  petId             String
  serviceId         String
  vehicleId         String?
  groomerId         String?
  recurringSeriesId String?
  status            AppointmentStatus @default(scheduled)
  scheduledStart    DateTime
  durationMin       Int
  serviceNameSnapshot         String
  servicePriceCentsSnapshot   Int
  serviceDepositCentsSnapshot Int
  serviceColorSnapshot        String
  serviceDurationMinSnapshot  Int
  addressOverrideStreet   String?
  addressOverrideCity     String?
  addressOverrideState    String?
  addressOverrideZip      String?
  addressOverrideLat      Float?
  addressOverrideLng      Float?
  addressOverrideVerified Boolean @default(false)
  depositChargeId   String?
  balanceChargeId   String?
  tipCents          Int               @default(0)
  finalAmountCents  Int?
  notes             String            @default("")
  mutationUuid      String?           @unique
  canceledAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pet             Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
  service         Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  groomer         User?            @relation("AppointmentGroomer", fields: [groomerId], references: [id], onDelete: SetNull)
  recurringSeries RecurringSeries? @relation(fields: [recurringSeriesId], references: [id], onDelete: SetNull)
  smsMessages     SmsMessage[]

  @@index([tenantId])
  @@index([tenantId, scheduledStart])
  @@index([tenantId, status, scheduledStart])
}

model RecurringSeries {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String
  petId         String
  serviceId     String
  intervalWeeks Int
  nextDueDate   DateTime
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pet          Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@index([tenantId])
  @@index([tenantId, active, nextDueDate])
}

model BookingPageRequest {
  id                     String               @id @default(cuid())
  tenantId               String
  clientId               String?
  serviceId              String
  petName                String
  petBreed               String
  petWeightLb            Float?
  petCoatType            CoatType
  petTemperamentNotes    String               @default("")
  petVaccinationExpiry   DateTime?
  ownerName              String
  ownerPhone             String
  ownerEmail             String?
  addressStreet          String
  addressCity            String
  addressState           String               @default("TX")
  addressZip             String
  addressLat             Float?
  addressLng             Float?
  requestedStart         DateTime
  durationMin            Int
  depositCents           Int
  depositPaymentIntentId String?              @unique
  status                 BookingRequestStatus @default(pending_payment)
  promotedAppointmentId  String?              @unique
  expiresAt              DateTime
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, expiresAt])
}

model SmsMessage {
  id              String       @id @default(cuid())
  tenantId        String
  clientId        String?
  appointmentId   String?
  direction       SmsDirection
  toE164          String
  fromE164        String
  body            String
  status          SmsStatus    @default(pending)
  twilioSid       String?      @unique
  idempotencyKey  String?
  errorMessage    String?
  sentAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, createdAt])
}

model WebhookEvent {
  id              String                  @id @default(cuid())
  source          WebhookSource
  eventId         String
  payload         Json
  status          WebhookProcessingStatus @default(received)
  processingError String?
  receivedAt      DateTime                @default(now())
  processedAt     DateTime?

  @@unique([source, eventId])
  @@index([status])
}
